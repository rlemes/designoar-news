---
import Base from '../../layouts/Base.astro';
import NewsCard from '../../components/NewsCard.astro';
import EditionNav from '../../components/EditionNav.astro';
import editionsIndex from '../../data/editions_index.json';
import { readFileSync } from 'fs';
import { join } from 'path';

export function getStaticPaths() {
  return editionsIndex.map(e => ({ params: { slug: e.date } }));
}

const { slug } = Astro.params;

const editionPath = join(process.cwd(), '..', 'data', 'editions', `${slug}.json`);
let edition: any = { date: slug, edition_number: 0, articles: [] };
try {
  edition = JSON.parse(readFileSync(editionPath, 'utf-8'));
} catch { /* edition not found */ }

const sortedIndex = [...editionsIndex].sort((a, b) => a.date > b.date ? -1 : 1);
const currentIdx = sortedIndex.findIndex(e => e.date === slug);
const prevDate = sortedIndex[currentIdx + 1]?.date ?? null;
const nextDate = sortedIndex[currentIdx - 1]?.date ?? null;

const { date, edition_number, articles } = edition;
const dateFormatted = date
  ? new Date(date + 'T12:00:00Z').toLocaleDateString('pt-BR', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' })
  : '';

const featured = articles[0] ?? null;
const rest = articles.slice(1);

const byCategory: Record<string, typeof articles> = {};
for (const a of rest) {
  if (!byCategory[a.category]) byCategory[a.category] = [];
  byCategory[a.category].push(a);
}
---

<Base title={`Designoar News #${edition_number}`}>

  <div class="issue-header">
    <div class="issue-header__inner">
      <div class="issue-meta">
        <span class="issue-badge">Edição #{edition_number}</span>
        {dateFormatted && <span class="issue-date">{dateFormatted}</span>}
      </div>
      <h1 class="issue-title">As melhores notícias<br /><em>de design desta semana</em></h1>
      <p class="issue-count">{articles.length} notícias selecionadas e traduzidas</p>
    </div>
  </div>

  <div class="content-wrap">
    {featured && (
      <section class="section-featured">
        <NewsCard article={featured} featured={true} />
      </section>
    )}

    {Object.entries(byCategory).map(([cat, arts]) => (
      <section class="cat-section">
        <h2 class="cat-heading"><span>{cat}</span></h2>
        <div class="grid">
          {arts.map((a: any) => <NewsCard article={a} />)}
        </div>
      </section>
    ))}

    <EditionNav prevDate={prevDate} nextDate={nextDate} />
  </div>
</Base>

<style>
  .issue-header {
    border-bottom: 1px solid #ebebeb;
    padding: 56px 40px 48px;
  }
  .issue-header__inner { max-width: 800px; }
  .issue-meta {
    display: flex; align-items: center; gap: 20px;
    margin-bottom: 20px;
    font-size: 12px; font-weight: 500;
    text-transform: uppercase; letter-spacing: 1px;
  }
  .issue-badge {
    background: #c8001e; color: white;
    padding: 4px 10px; font-size: 11px; font-weight: 700; letter-spacing: 1.5px;
  }
  .issue-date { color: #999; }
  .issue-title {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 400; line-height: 1.1;
    color: #0a0a0a; letter-spacing: -1px; margin-bottom: 16px;
  }
  .issue-title em { font-style: italic; color: #555; }
  .issue-count { font-size: 14px; color: #999; }

  .content-wrap {
    max-width: 1200px; margin: 0 auto; padding: 0 40px 40px;
  }
  .section-featured {
    padding: 48px 0 64px;
    margin-bottom: 64px;
    border-bottom: 1px solid #ebebeb;
  }
  .cat-section { margin-bottom: 64px; }
  .cat-heading {
    display: flex; align-items: center; gap: 16px;
    margin-bottom: 28px;
    font-size: 11px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 2px;
  }
  .cat-heading::after {
    content: ''; flex: 1; height: 1px; background: #ebebeb;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px 40px;
  }
  @media (max-width: 1024px) { .grid { grid-template-columns: repeat(2,1fr); } }
  @media (max-width: 640px) {
    .issue-header { padding: 36px 20px 28px; }
    .content-wrap { padding: 0 20px 32px; }
    .grid { grid-template-columns: 1fr; }
  }
</style>
