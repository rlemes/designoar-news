---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string | null;
}
const {
  title = "Designoar News",
  description = "As melhores notícias de design, toda semana.",
  ogImage = null,
} = Astro.props;
const pageTitle = `${title} — Designoar`;
const siteUrl = "https://designteam.com.br";
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{pageTitle}</title>

  <!-- Favicon: ponto vermelho em SVG inline -->
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><circle cx='50' cy='50' r='50' fill='%23c8001e'/></svg>" />

  <!-- OG / Social -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Designoar News" />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={siteUrl} />
  {ogImage && <meta property="og:image" content={ogImage} />}
  <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={description} />
  {ogImage && <meta name="twitter:image" content={ogImage} />}

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --white: #ffffff;
      --black: #0a0a0a;
      --gray-100: #f7f7f7;
      --gray-200: #ebebeb;
      --gray-400: #999;
      --gray-600: #555;
      --accent: #c8001e;      /* vermelho editorial, como Dezeen */
      --font-serif: 'DM Serif Display', Georgia, serif;
      --font-sans: 'DM Sans', system-ui, sans-serif;
    }

    html { font-size: 16px; -webkit-font-smoothing: antialiased; }

    body {
      background: var(--white);
      color: var(--black);
      font-family: var(--font-sans);
      line-height: 1.6;
      min-height: 100vh;
    }

    a { color: inherit; text-decoration: none; }
    img { max-width: 100%; display: block; }

    /* ─── HEADER ─── */
    .site-header {
      border-bottom: 2px solid var(--black);
      padding: 0 40px;
      display: flex;
      align-items: stretch;
      justify-content: space-between;
      background: var(--white);
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .site-logo {
      font-family: var(--font-serif);
      font-size: 22px;
      font-weight: 400;
      letter-spacing: -0.3px;
      color: var(--black);
      display: flex;
      align-items: center;
      padding: 18px 0;
      gap: 10px;
    }

    .site-logo .dot {
      width: 8px;
      height: 8px;
      background: var(--accent);
      border-radius: 50%;
      display: inline-block;
      flex-shrink: 0;
    }

    .site-nav {
      display: flex;
      align-items: center;
      gap: 0;
    }

    .site-nav a {
      font-size: 12px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--gray-600);
      padding: 0 20px;
      height: 100%;
      display: flex;
      align-items: center;
      border-left: 1px solid var(--gray-200);
      transition: color .15s, background .15s;
    }

    .site-nav a:hover { color: var(--black); background: var(--gray-100); }
    .site-nav a.cta { color: var(--white); background: var(--black); font-weight: 600; }
    .site-nav a.cta:hover { background: var(--accent); }

    /* ─── FOOTER ─── */
    .site-footer {
      border-top: 2px solid var(--black);
      padding: 40px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-size: 12px;
      color: var(--gray-400);
      text-transform: uppercase;
      letter-spacing: .8px;
      margin-top: 80px;
    }

    @media (max-width: 640px) {
      .site-header { padding: 0 20px; }
      .site-nav a { padding: 0 14px; font-size: 11px; }
      .site-nav a.cta { display: none; }
      .site-footer { flex-direction: column; gap: 8px; padding: 24px 20px; text-align: center; }
    }
  </style>
</head>
<body>
  <header class="site-header">
    <a href="/" class="site-logo">
      <span class="dot"></span>
      Designoar News
    </a>
    <nav class="site-nav">
      <a href="/">Atual</a>
      <a href="/edicoes/">Arquivo</a>
      <a href="https://designteam.com.br" target="_blank" rel="noopener" class="cta">designteam.com.br ↗</a>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <span>© Designoar News</span>
  </footer>
</body>
</html>
